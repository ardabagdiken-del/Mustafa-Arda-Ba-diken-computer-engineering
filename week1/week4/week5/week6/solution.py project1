# ── Main Solution ────────────────────────────────────────────────────────────

def simple_converter():
    celsius = float(input("Enter temperature in Celsius: "))

    # Calculate fahrenheit using the formula F = (C × 9/5) + 32
    fahrenheit = (celsius * 9/5) + 32

    # Print the result using an f-string
    print(f"{celsius}°C is equal to {fahrenheit}°F")


# ── Bonus (Direction Menu) ───────────────────────────────────────────────────

def advanced_converter():
    print("\n--- Temperature Converter Menu ---")
    print("1. Celsius to Fahrenheit (C→F)")
    print("2. Fahrenheit to Celsius (F→C)")
    
    choice = input("Select conversion direction (1 or 2): ")

    if choice == '1':
        c = float(input("Enter temperature in Celsius: "))
        f = (c * 9/5) + 32
        print(f"Result: {c}°C = {f:.2f}°F")
    elif choice == '2':
        f = float(input("Enter temperature in Fahrenheit: "))
        c = (f - 32) * 5/9
        print(f"Result: {f}°F = {c:.2f}°C")
    else:
        print("Invalid choice. Please select 1 or 2.")

# Run the program
if __name__ == "__main__":
    # You can call simple_converter() for the basic task 
    # or advanced_converter() for the bonus features.
    advanced_converter()
