scores = []

# TODO: use a for loop to collect 5 scores and append each to the list
print("Please enter 5 test scores:")
for i in range(5):
    score = float(input(f"Enter score {i + 1}: "))
    scores.append(score)

# TODO: calculate the average using sum() and len()
average = sum(scores) / len(scores)

# TODO: determine the grade with if/elif/else (A/B/C/D/F)
if average >= 90:
    grade = "A"
elif average >= 80:
    grade = "B"
elif average >= 70:
    grade = "C"
elif average >= 60:
    grade = "D"
else:
    grade = "F"

# TODO: print the average (1 decimal place) and the grade
print("-" * 20)
print(f"Your average score is: {average:.1f}")
print(f"Final Grade: {grade}")
