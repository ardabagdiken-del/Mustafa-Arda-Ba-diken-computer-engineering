/* 
  Exercise 3: Responsive Design
  =============================
  Targeting three main breakpoints:
  - Desktop: 1024px+
  - Tablet: 600px - 1023px
  - Mobile: < 600px
*/

:root {
  --primary-blue: #1a3a5c;
  --accent-gold: #e8a838;
  --bg-light: #f8f9fa;
  --text-dark: #2d3436;
  --white: #ffffff;
}

/* Base Styles */
* {
  box-sizing: border-box;
  margin: 0;
  padding: 0;
}

body {
  font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
  line-height: 1.6;
  color: var(--text-dark);
  background-color: var(--bg-light);
}

img {
  max-width: 100%; /* Flexible Media Pillar */
  height: auto;
  display: block;
}

/* Header & Navigation */
header {
  background-color: var(--primary-blue);
  color: var(--white);
  padding: 1rem 5%;
  position: sticky;
  top: 0;
  z-index: 1000;
}

.header-inner {
  display: flex;
  justify-content: space-between;
  align-items: center;
  max-width: 1200px;
  margin: 0 auto;
}

.logo {
  font-size: 1.5rem;
  font-weight: bold;
}

nav a {
  color: var(--white);
  text-decoration: none;
  margin-left: 1.5rem;
  font-weight: 500;
}

/* Hero Section */
#hero {
  text-align: center;
  padding: 4rem 1rem;
  background-color: var(--white);
  border-bottom: 1px solid #ddd;
}

#hero h1 {
  font-size: 2.5rem;
  color: var(--primary-blue);
}

/* Main Content Container */
main {
  max-width: 1200px;
  margin: 0 auto;
  padding: 2rem 5%;
}

section {
  margin-bottom: 4rem;
}

h2 {
  margin-bottom: 1rem;
  font-size: 1.8rem;
}

/* ===== FLEXBOX CARDS ===== */
.flex-container {
  display: flex;
  flex-wrap: wrap; /* Allows cards to wrap to next line */
  gap: 1.5rem;
  margin-top: 1.5rem;
}

.flex-card {
  background: var(--white);
  padding: 1.5rem;
  border-radius: 8px;
  box-shadow: 0 4px 6px rgba(0,0,0,0.05);
  /* Flex-basis: sets initial size. Grow/Shrink: allows adjustment */
  flex: 1 1 calc(33.333% - 1.5rem); 
  min-width: 250px; /* Forces wrap on smaller screens */
}

/* ===== CSS GRID GALLERY ===== */
.photo-grid {
  display: grid;
  /* Auto-fit creates columns based on min-max width automatically */
  grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
  gap: 1rem;
}

.grid-item {
  position: relative;
  overflow: hidden;
  border-radius: 8px;
}

.caption {
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  background: rgba(0,0,0,0.7);
  color: white;
  padding: 0.5rem;
  font-size: 0.9rem;
  text-align: center;
}

/* Featured item logic - Desktop only */
@media (min-width: 900px) {
  .grid-item.featured {
    grid-column: span 2;
    grid-row: span 1;
  }
}

/* ===== MEDIA QUERIES (The 3rd Pillar) ===== */

/* Tablet & Smaller */
@media (max-width: 850px) {
  .header-inner {
    flex-direction: column;
    gap: 1rem;
  }
  
  nav a {
    margin: 0 0.75rem;
  }
}

/* Mobile Devices */
@media (max-width: 600px) {
  #hero h1 {
    font-size: 1.8rem;
  }

  .flex-card {
    flex: 1 1 100%; /* Force cards to full width */
  }

  nav {
    display: grid;
    grid-template-columns: 1fr 1fr;
    text-align: center;
    gap: 0.5rem;
  }

  nav a {
    margin: 0;
    padding: 0.5rem;
    background: rgba(255,255,255,0.1);
    border-radius: 4px;
  }
}

/* Footer */
footer {
  text-align: center;
  padding: 3rem 1rem;
  background-color: var(--primary-blue);
  color: white;
}
