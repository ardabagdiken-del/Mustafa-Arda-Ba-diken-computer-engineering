/**
 * Exercise 7: Notes App & localStorage
 * =====================================
 * Managing persistent data in the browser.
 */

// Global State
let notes = JSON.parse(localStorage.getItem('my_notes')) || [];
let editModeId = null;

// Selectors
const noteForm = document.querySelector('#note-form');
const titleInput = document.querySelector('#note-title');
const bodyInput = document.querySelector('#note-body');
const notesContainer = document.querySelector('#notes-container');
const searchInput = document.querySelector('#search-input');
const cancelBtn = document.querySelector('#btn-cancel');
const formTitle = document.querySelector('#form-title');

// ============================================================
// CORE FUNCTIONS
// ============================================================

function saveToLocalStorage() {
  localStorage.setItem('my_notes', JSON.stringify(notes));
  renderNotes();
}

function renderNotes(filter = "") {
  notesContainer.innerHTML = "";
  
  // Filter notes based on search input
  const filteredNotes = notes.filter(n => 
    n.title.toLowerCase().includes(filter.toLowerCase()) || 
    n.body.toLowerCase().includes(filter.toLowerCase())
  );

  document.querySelector('#notes-count').textContent = `${filteredNotes.length} notes found`;

  if (filteredNotes.length === 0) {
    notesContainer.innerHTML = '<p class="empty-state">No notes found. Create one!</p>';
    return;
  }

  filteredNotes.forEach(note => {
    const noteCard = document.createElement('div');
    noteCard.className = 'note-card';
    noteCard.innerHTML = `
      <div class="note-header">
        <h3>${note.title}</h3>
        <div class="note-actions">
          <button class="btn-edit" onclick="startEdit('${note.id}')">✏️</button>
          <button class="btn-delete" onclick="deleteNote('${note.id}')">🗑️</button>
        </div>
      </div>
      <p>${note.body}</p>
      <small>${note.date}</small>
    `;
    notesContainer.appendChild(noteCard);
  });
}

// ============================================================
// EVENT HANDLERS
// ============================================================

noteForm.addEventListener('submit', (e) => {
  e.preventDefault();

  const newNote = {
    id: editModeId || Date.now().toString(),
    title: titleInput.value,
    body: bodyInput.value,
    date: new Date().toLocaleString()
  };

  if (editModeId) {
    // Update existing note
    notes = notes.map(n => n.id === editModeId ? newNote : n);
    exitEditMode();
  } else {
    // Create new note
    notes.unshift(newNote); // Add to beginning
  }

  saveToLocalStorage();
  noteForm.reset();
});

function deleteNote(id) {
  if (confirm("Are you sure you want to delete this note?")) {
    notes = notes.filter(n => n.id !== id);
    saveToLocalStorage();
  }
}

function startEdit(id) {
  const noteToEdit = notes.find(n => n.id === id);
  if (!noteToEdit) return;

  editModeId = id;
  titleInput.value = noteToEdit.title;
  bodyInput.value = noteToEdit.body;

  // UI Changes
  formTitle.textContent = "Edit Note";
  cancelBtn.classList.remove('hidden');
  document.querySelector('#btn-submit').textContent = "💾 Update Note";
  titleInput.focus();
}

function exitEditMode() {
  editModeId = null;
  formTitle.textContent = "New Note";
  cancelBtn.classList.add('hidden');
  document.querySelector('#btn-submit').textContent = "💾 Save Note";
  noteForm.reset();
}

// Search Functionality
searchInput.addEventListener('input', (e) => {
  renderNotes(e.target.value);
});

cancelBtn.addEventListener('click', exitEditMode);

// Initial Load
renderNotes();
