/* 
  Exercise 3: Responsive Design
  ==============================
  MOBILE-FIRST: Base styles for small screens, 
  enhanced with min-width media queries.
*/

/* ===== TODO: CSS Custom Properties ===== */
:root {
  --primary: #1a3a5c;
  --accent: #e8a838;
  --bg: #f8f9fa;
  --text: #2d3436;
  --white: #ffffff;
  --gap: 1.5rem;
  --container-max: 1200px;
}

/* ===== TODO: Base Styles (Mobile First) ===== */
* { 
  box-sizing: border-box; 
  margin: 0; 
  padding: 0; 
}

body {
  font-family: system-ui, -apple-system, sans-serif;
  background-color: var(--bg);
  color: var(--text);
  line-height: 1.6;
}

/* ===== TODO Task 2: Header & Nav (mobile: stacked) ===== */
header {
  background-color: var(--primary);
  color: var(--white);
  padding: 1rem;
}

.header-inner {
  display: flex;
  flex-direction: column; /* Stacked on mobile */
  align-items: center;
  gap: 1rem;
  max-width: var(--container-max);
  margin: 0 auto;
}

.logo {
  font-size: 1.5rem;
  font-weight: bold;
  letter-spacing: -1px;
}

nav {
  display: flex;
  flex-direction: column; /* Links in a column on mobile */
  width: 100%;
  text-align: center;
}

nav a {
  color: var(--white);
  text-decoration: none;
  padding: 0.75rem; /* Large tap targets */
  min-height: 44px;
  display: block;
  transition: background 0.3s;
}

nav a:hover {
  background-color: rgba(255, 255, 255, 0.1);
}

/* ===== TODO Task 5: Hero Section ===== */
#hero {
  text-align: center;
  padding: 4rem 1.5rem;
  background-color: var(--white);
}

#hero h1 {
  /* Fluid typography: Min 1.8rem, scales with width, Max 3.5rem */
  font-size: clamp(1.8rem, 8vw, 3.5rem);
  color: var(--primary);
  margin-bottom: 1rem;
}

/* ===== TODO Task 3: Flexbox Cards ===== */
.flex-container {
  display: flex;
  flex-wrap: wrap;
  gap: var(--gap);
}

.flex-card {
  background: var(--white);
  padding: 1.5rem;
  border-radius: 8px;
  box-shadow: 0 2px 5px rgba(0,0,0,0.1);
  /* Grow and shrink, basis of 250px ensures wrap */
  flex: 1 1 250px;
}

/* ===== TODO Task 4: CSS Grid Gallery ===== */
.photo-grid {
  display: grid;
  grid-template-columns: 1fr; /* 1 column on mobile */
  gap: 1rem;
}

.grid-item {
  position: relative;
  overflow: hidden;
  border-radius: 8px;
  background: #ddd;
}

.grid-item img {
  width: 100%;
  height: 100%;
  object-fit: cover;
  display: block;
}

.caption {
  position: absolute;
  bottom: 0;
  background: rgba(0,0,0,0.6);
  color: white;
  width: 100%;
  padding: 0.5rem;
  font-size: 0.85rem;
}

/* ===== TODO: Footer ===== */
footer {
  text-align: center;
  padding: 3rem 1rem;
  background: var(--primary);
  color: var(--white);
  margin-top: 4rem;
}

/* ===== TODO: Sections ===== */
section {
  padding: 2rem 1.5rem;
  max-width: var(--container-max);
  margin: 0 auto;
}

/* ============================================
   TABLET (600px+)
   ============================================ */
@media (min-width: 600px) {

  /* Nav becomes horizontal */
  .header-inner {
    flex-direction: row;
    justify-content: space-between;
  }

  nav {
    flex-direction: row;
    width: auto;
  }

  /* Grid becomes 2 columns */
  .photo-grid {
    grid-template-columns: repeat(2, 1fr);
  }

  /* Make the .featured item span 2 columns */
  .featured {
    grid-column: span 2;
  }
}

/* ============================================
   DESKTOP (900px+)
   ============================================ */
@media (min-width: 900px) {

  /* Grid becomes 3 columns */
  .photo-grid {
    grid-template-columns: repeat(3, 1fr);
  }
  
  /* Feature logic: if 3 columns, featured spans 2 */
  .featured {
    grid-column: span 2;
    grid-row: span 1;
  }
}

/* ============================================
   WIDE (1200px+)
   ============================================ */
@media (min-width: 1200px) {
  /* Increase padding for very large screens */
  section {
    padding: 4rem 0;
  }
}
