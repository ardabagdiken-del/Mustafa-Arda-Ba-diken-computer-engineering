/* General Reset & Typography */
* {
    box-sizing: border-box;
    margin: 0;
    padding: 0;
}

body {
    font-family: 'Inter', sans-serif;
    line-height: 1.6;
    color: #333;
    background-color: #f4f7f6;
}

/* Hero Header */
#hero {
    background: linear-gradient(135deg, #1e3c72 0%, #2a5298 100%);
    color: white;
    padding: 4rem 2rem;
    text-align: center;
}

#hero h1 {
    font-size: 2.5rem;
    margin-bottom: 0.5rem;
}

/* Navigation */
nav {
    background-color: #333;
    display: flex;
    justify-content: center;
    padding: 1rem;
    position: sticky;
    top: 0;
    z-index: 100;
}

nav a {
    color: white;
    text-decoration: none;
    margin: 0 1.5rem;
    font-weight: bold;
    transition: color 0.3s;
}

nav a:hover {
    color: #ffcc00;
}

/* Main Layout */
main {
    max-width: 900px;
    margin: 2rem auto;
    padding: 0 1rem;
}

section {
    margin-bottom: 3rem;
}

h2 {
    border-bottom: 2px solid #2a5298;
    padding-bottom: 0.5rem;
    margin-bottom: 1rem;
    color: #1e3c72;
}

/* Paragraph Styling & Pseudo-element */
p {
    margin-bottom: 1rem;
}

.intro {
    font-size: 1.2rem;
    color: #555;
    font-style: italic;
}

/* Target the first letter of the third paragraph in #about */
#about p:nth-of-type(3)::first-letter {
    font-size: 3rem;
    font-weight: bold;
    color: #1e3c72;
    float: left;
    margin-right: 0.5rem;
    line-height: 1;
}

/* Card Grid Layout */
.card-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
    gap: 1.5rem;
    margin-top: 1rem;
}

.card {
    background: white;
    padding: 1.5rem;
    border-radius: 8px;
    border: 1px solid #ddd;
    box-shadow: 0 4px 6px rgba(0,0,0,0.05);
    transition: transform 0.3s;
}

.card:hover {
    transform: translateY(-5px);
}

.card h3 {
    margin-bottom: 0.75rem;
    color: #2a5298;
}

/* Fancy Alternating List */
.fancy-list {
    list-style: none;
    border-radius: 8px;
    overflow: hidden;
}

.fancy-list li {
    padding: 0.75rem 1rem;
    background-color: white;
}

.fancy-list li:nth-child(even) {
    background-color: #e9ecef;
}

/* Footer */
footer {
    text-align: center;
    padding: 2rem;
    color: #777;
    font-size: 0.9rem;
    border-top: 1px solid #ddd;
}
