-- Verification queries:
-- Q1: Who does user 1 follow?
SELECT username FROM users WHERE id IN (SELECT followed_id FROM follows WHERE follower_id = 1);

-- Q2: Most liked posts?
SELECT posts.content, COUNT(likes.user_id) AS total_likes 
FROM posts 
JOIN likes ON posts.id = likes.post_id 
GROUP BY posts.id 
ORDER BY total_likes DESC;

-- Q3: User who posted the most?
SELECT username, COUNT(posts.id) AS post_count 
FROM users 
JOIN posts ON users.id = posts.user_id 
GROUP BY users.id 
ORDER BY post_count DESC 
LIMIT 1;
