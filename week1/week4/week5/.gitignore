inheritance
speller
volume

# CS50 configuration files
.cs50.yml

# macOS system files
# These are hidden files created by the macOS Finder.
.DS_Store

# Editor temporary and configuration files
# These store your personal editor state and settings.
*.swp
*.swo
.vscode/

# Build artifacts
# If your Makefile creates .o files, they should be ignored here.
*.o
